  "cloudSyncGuideTitle": "Cloud Sync Guide",
  "cloudSyncGuideGotIt": "Got it",
  "cloudSyncGuideHowItWorks": "How it works",
  "cloudSyncGuideHowItem1": "Upload: packages all current ledger data and uploads to cloud, replacing old cloud data",
  "cloudSyncGuideHowItem2": "Download: fetches cloud data and compares with local records one by one — you choose which changes to apply",
  "cloudSyncGuideHowItem3": "The cloud always stores only the last uploaded snapshot, no version history",
  "cloudSyncGuideCorrect": "Correct usage",
  "cloudSyncGuideCorrectItem1": "Edit on one device at a time, upload when done",
  "cloudSyncGuideCorrectItem2": "Download on the new device before starting to edit",
  "cloudSyncGuideCorrectItem3": "Review the preview carefully before applying changes",
  "cloudSyncGuideCorrectItem4": "Follow the pattern: edit → upload → switch device → download → edit",
  "cloudSyncGuideWrong": "What to avoid",
  "cloudSyncGuideWrongItem1": "Editing the same ledger on two devices simultaneously — the later upload overwrites the earlier one",
  "cloudSyncGuideWrongItem2": "Downloading immediately after upload — cloud services may have seconds to minutes of sync delay, wait a moment",
  "cloudSyncGuideWrongItem3": "Going long periods without syncing then downloading many changes at once — easy to miss important differences",
  "cloudSyncGuideLimitations": "Known limitations",
  "cloudSyncGuideLimitItem1": "Not real-time: requires manually tapping upload and download",
  "cloudSyncGuideLimitItem2": "No conflict merging: does not auto-merge edits from both sides — last upload wins",
  "cloudSyncGuideLimitItem3": "Cloud service delay: uploaded files may take seconds to minutes before other devices can read them, depending on your cloud provider",
  "cloudSyncGuideLimitItem4": "Excludes attachments: transaction image attachments are not synced — export separately via Data Management",
